COMPOSE_PROJECT_NAME=cliu-rag

APP_ENV=PROD
APP_BASE_PATH=/rag
VITE_API_BASE_PATH=/rag

FRONTEND_EXTERNAL_PORT=8000
FRONTEND_INTERNAL_PORT=80

BACKEND_EXTERNAL_PORT=8080
BACKEND_INTERNAL_PORT=8080
BACKEND_UPSTREAM=http://backend:8080

DB_EXTERNAL_PORT=5432
DB_NAME=rag_platform
DB_USER=rag_user
DB_PASSWORD=change_me_strong
DB_SSLMODE=disable

POSTGRES_VOLUME_DIR=/srv/rag/postgres
UPLOADS_VOLUME_DIR=/srv/rag/uploads

ADMIN_USERNAME=admin
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_me_strong

SESSION_COOKIE_NAME=interview_copilot_session
SESSION_TTL_HOURS=24
SECURE_COOKIES=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://your-domain.com/rag/api/auth/google/callback
FRONTEND_POST_LOGIN_URL=https://your-domain.com/rag/

CORS_ALLOWED_ORIGINS=https://your-domain.com
CORS_ALLOW_CREDENTIALS=true

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_URL=
LOCAL_EMBEDDING_API_KEY=
LOCAL_EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest
LOCAL_EMBEDDING_DIM=0
DISABLE_EMBEDDING_PROBE=false
ENABLE_HNSW_INDEX=true

RERANKER_PROVIDER=none
RERANKER_TOP_K=5