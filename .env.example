DB_HOST=localhost
DB_PORT=5432
DB_USER=rag_user
DB_PASSWORD=rag_password
DB_NAME=rag_platform
DB_SSLMODE=disable
lLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

LOCAL_EMBEDDING_URL=
LOCAL_EMBEDDING_API_KEY=
LOCAL_EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest
LOCAL_EMBEDDING_DIM=0
ENABLE_HNSW_INDEX=true
DISABLE_EMBEDDING_PROBE=false


HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=2
HTTP_RETRY_BASE_DELAY_MS=500
HTTP_CIRCUIT_THRESHOLD=3
HTTP_CIRCUIT_COOLDOWN_SECONDS=30

# ===== SERVER =====
PORT=8080

# ===== DATABASE =====
DATABASE_URL=postgres://postgres:password@localhost:5432/rag_db?sslmode=disable

# ===== AUTH (ADMIN) =====
ADMIN_USERNAME=admin
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=replace_me

# ===== SESSION =====
SESSION_COOKIE_NAME=interview_copilot_session
SESSION_TTL_HOURS=24
SECURE_COOKIES=false

# ===== ACCOUNT LIFECYCLE =====
LOCAL_RECRUITER_TTL_DAYS=30
GOOGLE_RECRUITER_TTL_DAYS=365

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
# Production example (future)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# SECURE_COOKIES=true
# ===== EMBEDDING / RAG =====
EMBEDDING_PROVIDER=openai


# ===== RERANKER =====
RERANKER_PROVIDER=ollama
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_URL=
RERANKER_API_KEY=
RERANKER_TOP_K=5