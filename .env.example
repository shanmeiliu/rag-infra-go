# ============================================================
# App environment
# ============================================================
# DEV: local development with go run ./cmd/api
# PROD: production / Docker / server deployment
APP_ENV=DEV

# Backend HTTP port
PORT=8080

# ============================================================
# Database
# ============================================================
# Local DEV example:
DB_HOST=localhost
DB_PORT=5432
DB_USER=rag_user
DB_PASSWORD=rag_password
DB_NAME=rag_platform
DB_SSLMODE=disable

# Docker Compose overrides DB_HOST internally to "db".
# For Docker DB persistent volume:
# DEV example:
POSTGRES_VOLUME_DIR=./docker-data/postgres
# PROD example:
# POSTGRES_VOLUME_DIR=/srv/rag-infra/postgres

# Uploaded source files volume:
UPLOADS_VOLUME_DIR=./docker-data/uploads
# PROD example:
# UPLOADS_VOLUME_DIR=/srv/rag-infra/uploads

# ============================================================
# LLM provider
# ============================================================
# Current code uses OpenAI-compatible config.
# For OpenAI:
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_BASE_URL=http://localhost:11434/v1
LLM_FALLBACK_API_KEY=ollama
LLM_FALLBACK_CHAT_MODEL=qwen2.5:7b
# For OpenRouter example:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openrouter_key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_CHAT_MODEL=openai/gpt-4o-mini

# ============================================================
# Embeddings
# ============================================================
# Options: openai, local, ollama depending on your provider code
EMBEDDING_PROVIDER=local

# OpenAI embedding example:
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local OpenAI-compatible embedding endpoint example:
LOCAL_EMBEDDING_URL=
LOCAL_EMBEDDING_API_KEY=
LOCAL_EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest

# 0 = detect dimension from provider probe
LOCAL_EMBEDDING_DIM=0
DISABLE_EMBEDDING_PROBE=false

# HNSW vector index
ENABLE_HNSW_INDEX=true

# ============================================================
# HTTP provider resiliency
# ============================================================
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=2
HTTP_RETRY_BASE_DELAY_MS=500
HTTP_CIRCUIT_THRESHOLD=3
HTTP_CIRCUIT_COOLDOWN_SECONDS=30

# ============================================================
# Auth admin
# ============================================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=replace_me

# ============================================================
# Session
# ============================================================
SESSION_COOKIE_NAME=interview_copilot_session
SESSION_TTL_HOURS=24

# DEV:
SECURE_COOKIES=false
# PROD with HTTPS:
# SECURE_COOKIES=true

# ============================================================
# Account lifecycle
# ============================================================
LOCAL_RECRUITER_TTL_DAYS=30
GOOGLE_RECRUITER_TTL_DAYS=365

# ============================================================
# Google OAuth
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# DEV:
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
FRONTEND_POST_LOGIN_URL=http://localhost:5173/

# PROD example if frontend is hosted at https://yourdomain.com/rag:
# GOOGLE_REDIRECT_URL=https://yourdomain.com/rag/api/auth/google/callback
# FRONTEND_POST_LOGIN_URL=https://yourdomain.com/rag/

# Optional: restrict Google OAuth to one domain
GOOGLE_ALLOWED_DOMAIN=

# ============================================================
# CORS
# ============================================================
# DEV:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# PROD examples:
# If browser calls backend directly:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
#
# If frontend and API are same-origin behind Nginx, this still does not hurt:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ============================================================
# Reranker
# ============================================================
# none, ollama, http depending on your current reranker code
RERANKER_PROVIDER=none
RERANKER_MODEL=
RERANKER_URL=
RERANKER_API_KEY=
RERANKER_TOP_K=5

# Ollama reranker example:
# RERANKER_PROVIDER=http
# RERANKER_MODEL=bona/bge-reranker-v2-m3:latest
# RERANKER_URL=http://host.docker.internal:11434/api/rerank
# RERANKER_API_KEY=
# RERANKER_TOP_K=5

#=============================================================
# MFA
#=============================================================
MFA_REQUIRED_FOR_ADMIN=true
MFA_ISSUER=Interview Copilot

MFA_EMAIL_BACKUP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=